{
  "name": "@resource-fallback/core",
  "version": "0.1.5",
  "description": "Browser runtime + Node helpers for resource-fallback (multi-CDN retry & fallback)",
  "keywords": [
    "cdn",
    "fallback",
    "resource",
    "retry",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/ben-lau/resource-fallback/tree/main/packages/core#readme",
  "bugs": "https://github.com/ben-lau/resource-fallback/issues",
  "license": "MIT",
  "author": "ben-lau <408736066@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ben-lau/resource-fallback.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runtime": {
      "default": "./dist/runtime.iife.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  }
}
