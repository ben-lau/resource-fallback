{
  "name": "@resource-fallback/webpack-plugin",
  "version": "0.2.0",
  "description": "Webpack 5 plugin that wires @resource-fallback/core into your build (HTML injection + chunkLoadingGlobal forwarding)",
  "keywords": [
    "cdn",
    "fallback",
    "retry",
    "webpack",
    "webpack-plugin"
  ],
  "homepage": "https://github.com/ben-lau/resource-fallback/tree/main/packages/webpack-plugin#readme",
  "bugs": "https://github.com/ben-lau/resource-fallback/issues",
  "license": "MIT",
  "author": "ben-lau <408736066@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ben-lau/resource-fallback.git",
    "directory": "packages/webpack-plugin"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@resource-fallback/core": "workspace:*"
  },
  "devDependencies": {
    "html-webpack-plugin": "^5.6.3",
    "webpack": "^5.108.4"
  },
  "peerDependencies": {
    "html-webpack-plugin": ">=4",
    "webpack": ">=5"
  },
  "peerDependenciesMeta": {
    "html-webpack-plugin": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
