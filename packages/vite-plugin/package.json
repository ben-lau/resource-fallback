{
  "name": "@resource-fallback/vite-plugin",
  "version": "0.2.0",
  "description": "Vite 4+ plugin that wires @resource-fallback/core into your build (HTML injection + dynamic import rewriting)",
  "keywords": [
    "cdn",
    "fallback",
    "retry",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/ben-lau/resource-fallback/tree/main/packages/vite-plugin#readme",
  "bugs": "https://github.com/ben-lau/resource-fallback/issues",
  "license": "MIT",
  "author": "ben-lau <408736066@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ben-lau/resource-fallback.git",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@resource-fallback/core": "workspace:*",
    "es-module-lexer": "^2.3.1",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "vite": "^6.4.3"
  },
  "peerDependencies": {
    "vite": ">=4"
  },
  "engines": {
    "node": ">=18"
  }
}
