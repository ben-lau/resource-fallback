{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-this-alias": "off",
    "oxc/const-comparisons": "off",
    "unicorn/prefer-string-starts-ends-with": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**",
    "examples/**"
  ]
}
