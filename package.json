{
  "name": "resource-fallback",
  "version": "0.0.0",
  "private": true,
  "description": "Frontend resource fallback monorepo: retry + multi-CDN + origin recovery for Webpack & Vite",
  "homepage": "https://github.com/ben-lau/resource-fallback#readme",
  "bugs": "https://github.com/ben-lau/resource-fallback/issues",
  "license": "MIT",
  "author": "ben-lau <408736066@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ben-lau/resource-fallback.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build",
    "build:core": "pnpm --filter @resource-fallback/core run build",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter='./packages/*' run typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache",
    "publint": "pnpm -r --filter='./packages/*' exec publint",
    "attw": "pnpm -r --filter='./packages/*' exec attw --pack --entrypoints .",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "release": "pnpm build && pnpm -r --filter='./packages/*' publish",
    "prepare": "lefthook install",
    "docs:typedoc": "typedoc",
    "docs:dev": "pnpm docs:typedoc && vitepress dev docs",
    "docs:build": "pnpm docs:typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@braintree/sanitize-url": "^7.1.2",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@size-limit/file": "^12.1.0",
    "@swc/core": "^1.15.41",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.21",
    "debug": "^4.4.3",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.8"
  },
  "size-limit": [
    {
      "path": "packages/core/dist/runtime.iife.js",
      "limit": "30 kB"
    },
    {
      "path": "packages/core/dist/rf-sw.js",
      "limit": "5 kB"
    }
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.7.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@esbuild/darwin-arm64",
      "@esbuild/darwin-x64",
      "@esbuild/linux-x64",
      "@swc/core"
    ],
    "overrides": {
      "esbuild": "0.21.5",
      "terser": "^5.46.2"
    }
  }
}
