{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "group-pull-request-title-pattern": "chore: release v${version}",
  "packages": {
    "packages/core": {
      "component": "@resource-fallback/core"
    },
    "packages/vite-plugin": {
      "component": "@resource-fallback/vite-plugin"
    },
    "packages/webpack-plugin": {
      "component": "@resource-fallback/webpack-plugin"
    }
  },
  "linked-versions": {
    "resource-fallback": {
      "component": "resource-fallback",
      "packages": ["packages/core", "packages/vite-plugin", "packages/webpack-plugin"]
    }
  }
}
